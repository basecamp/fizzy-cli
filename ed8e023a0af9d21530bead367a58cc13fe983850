x, br*4+dy) {\n\t\t\t\tif dx == 0 {\n\t\t\t\t\tif dy < 3 {\n\t\t\t\t\t\tval |= 1 << uint(dy)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tval |= 1 << 6\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tif dy < 3 {\n\t\t\t\t\t\tval |= 1 << uint(dy+3)\n\t\t\t\t\t} else {\n\t\t\t\t\t\tval |= 1 << 7\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn val\n}\n\nfunc renderBraille(grid []string) []string {\n\th := len(grid)\n\tw := gridWidth(grid)\n\tbRows := (h + 3) / 4\n\tbCols := (w + 1) / 2\n\n\tresult := make([]string, bRows)\n\tfor br := 0; br < bRows; br++ {\n\t\tvar b strings.Builder\n\t\tfor bc := 0; bc < bCols; bc++ {\n\t\t\tb.WriteRune(rune(0x2800 + int(brailleBits(grid, bc, br))))\n\t\t}\n\t\tresult[br] = b.String()\n\t}\n\treturn result\n}\n\nfunc renderHalfBlock(grid []string) []string {\n\th := len(grid)\n\tw := gridWidth(grid)\n\ttRows := (h + 1) / 2\n\n\tresult := make([]string, tRows)\n\tfor tr := 0; tr < tRows; tr++ {\n\t\tvar b strings.Builder\n\t\tfor c := 0; c < w; c++ {\n\t\t\ttop := pixelAt(grid, c, tr*2)\n\t\t\tbot := pixelAt(grid, c, tr*2+1)\n\t\t\tswitch {\n\t\t\tcase top && bot:\n\t\t\t\tb.WriteRune('в–Ҳ')\n\t\t\tcase top:\n\t\t\t\tb.WriteRune('в–Җ')\n\t\t\tcase bot:\n\t\t\t\tb.WriteRune('в–„')\n\t\t\tdefault:\n\t\t\t\tb.WriteRune(' ')\n\t\t\t}\n\t\t}\n\t\tresult[tr] = b.String()\n\t}\n\treturn result\n}\n\n// renderHybrid uses в–Ҳв–Җв–„ for fully solid regions and braille for partial/edge cells.\nfunc renderHybrid(grid []string) []string {\n\th := len(grid)\n\tw := gridWidth(grid)\n\tbRows := (h + 3) / 4\n\tbCols := (w + 1) / 2\n\n\tresult := make([]string, bRows)\n\tfor br := 0; br < bRows; br++ {\n\t\tvar b strings.Builder\n\t\tfor bc := 0; bc < bCols; bc++ {\n\t\t\t// Count filled pixels in top half (rows 0-1) and bottom half (rows 2-3)\n\t\t\tvar topCount, botCount int\n\t\t\tfor dy := 0; dy < 4; dy++ {\n\t\t\t\tfor dx := 0; dx < 2; dx++ {\n\t\t\t\t\tif pixelAt(grid, bc*2+dx, br*4+dy) {\n\t\t\t\t\t\tif dy < 2 {\n\t\t\t\t\t\t\ttopCount++\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tbotCount++\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tswitch {\n\t\t\tcase topCount == 4 && botCount == 4:\n\t\t\t\tb.WriteRune('в–Ҳ')\n\t\t\tcase topCount == 4 && botCount == 0:\n\t\t\t\tb.WriteRune('в–Җ')\n\t\t\tcase topCount == 0 && botCount == 4:\n\t\t\t\tb.WriteRune('в–„')\n\t\t\tcase topCount == 0 && botCount == 0:\n\t\t\t\tb.WriteRune(' ')\n\t\t\tdefault:\n\t\t\t\tb.WriteRune(rune(0x2800 + int(brailleBits(grid, bc, br))))\n\t\t\t}\n\t\t}\n\t\tresult[br] = b.String()\n\t}\n\treturn result\n}\n\nfunc scale2x(grid []string) []string {\n\tresult := make([]string, len(grid)*2)\n\tfor i, row := range grid {\n\t\tvar b strings.Builder\n\t\tfor _, ch := range row {\n\t\t\tb.WriteByte(byte(ch))\n\t\t\tb.WriteByte(byte(ch))\n\t\t}\n\t\tdoubled := b.String()\n\t\tresult[i*2] = doubled\n\t\tresult[i*2+1] = doubled\n\t}\n\treturn result\n}\n\n// --- Composition ---\n\ntype letterDef struct {\n\tpixels []string\n\tcolor  lipgloss.Color\n}\n\nvar fizzyLetters = []letterDef{\n\t{pixCapF, tui.PopsicleColors[0]},\n\t{pixLowerI, tui.PopsicleColors[1]},\n\t{pixLowerZ, tui.PopsicleColors[2]},\n\t{pixLowerZ, tui.PopsicleColors[3]},\n\t{pixLowerY, tui.PopsicleColors[4]},\n}\n\nfunc composeFizzy(letters []letterDef, renderer func([]string) []string, transform func([]string) []string, re *lipgloss.Renderer, gap string) []string {\n\trenders := make([][]string, len(letters))\n\twidths := make([]int, len(letters))\n\tmaxH := 0\n\n\tfor i, l := range letters {\n\t\tpx := l.pixels\n\t\tif transform != nil {\n\t\t\tpx = transform(px)\n\t\t}\n\t\trenders[i] = renderer(px)\n\t\tif len(renders[i]) > maxH {\n\t\t\tmaxH = len(renders[i])\n\t\t}\n\t\tfor _, row := range renders[i] {\n\t\t\tif w := len([]rune(row)); w > widths[i] {\n\t\t\t\twidths[i] = w\n\t\t\t}\n\t\t}\n\t}\n\n\tresult := make([]string, maxH)\n\tfor row := 0; row < maxH; row++ {\n\t\tvar b strings.Builder\n\t\tfor li, l := range letters {\n\t\t\tif li > 0 {\n\t\t\t\tb.WriteString(gap)\n\t\t\t}\n\t\t\tvar text string\n\t\t\tif row < len(renders[li]) {\n\t\t\t\ttext = renders[li][row]\n\t\t\t}\n\t\t\tpad := widths[li] - len([]rune(text))\n\t\t\tif pad > 0 {\n\t\t\t\ttext += strings.Repeat(\" \", pad)\n\t\t\t}\n\t\t\tstyle := re.NewStyle().Foreground(l.color)\n\t\t\tb.WriteString(style.Render(text))\n\t\t}\n\t\tresult[row] = b.String()\n\t}\n\treturn result\n}\n\nfunc renderPopsicleArt(re *lipgloss.Renderer) []string {\n\tvar styles [5]lipgloss.Style\n\tfor i := 0; i < 5; i++ {\n\t\tstyles[i] = re.NewStyle().Foreground(tui.PopsicleColors[i])\n\t}\n\n\tlines := strings.Split(tui.Banner, \"\\n\")\n\tresult := make([]string, len(lines))\n\tfor i, line := range lines {\n\t\trunes := []rune(line)\n\t\tif len(runes) > 26 {\n\t\t\trunes = runes[:26]\n\t\t}\n\n\t\tvar b strings.Builder\n\t\tj := 0\n\t\tfor j < len(runes) {\n\t\t\tz := popsicleZone(j)\n\t\t\tif z >= 5 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tk := j + 1\n\t\t\tfor k < len(runes) && popsicleZone(k) == z {\n\t\t\t\tk++\n\t\t\t}\n\t\t\tvar run strings.Builder\n\t\t\tfor x := j; x < k; x++ {\n\t\t\t\tif isDense(runes[x]) {\n\t\t\t\t\trun.WriteRune(runes[x])\n\t\t\t\t} else {\n\t\t\t\t\trun.WriteRune(blankBraille)\n\t\t\t\t}\n\t\t\t}\n\t\t\tb.WriteString(styles[z].Render(run.String()))\n\t\t\tj = k\n\t\t}\n\t\tresult[i] = b.String()\n\t}\n\treturn result\n}\n\nfunc renderFullBanner(re *lipgloss.Renderer) []string {\n\tvar styles [6]lipgloss.Style\n\tfor i := 0; i < 5; i++ {\n\t\tstyles[i] = re.NewStyle().Foreground(tui.PopsicleColors[i])\n\t}\n\tstyles[5] = re.NewStyle()\n\n\tlines := strings.Split(tui.Banner, \"\\n\")\n\tresult := make([]string, len(lines))\n\tfor i, line := range lines {\n\t\trunes := []rune(line)\n\t\tvar b strings.Builder\n\t\tj := 0\n\t\tfor j < len(runes) {\n\t\t\tz := popsicleZone(j)\n\t\t\tk := j + 1\n\t\t\tfor k < len(runes) && popsicleZone(k) == z {\n\t\t\t\tk++\n\t\t\t}\n\t\t\tvar run strings.Builder\n\t\t\tfor x := j; x < k; x++ {\n\t\t\t\tif isDense(runes[x]) {\n\t\t\t\t\trun.WriteRune(runes[x])\n\t\t\t\t} else {\n\t\t\t\t\trun.WriteRune(blankBraille)\n\t\t\t\t}\n\t\t\t}\n\t\t\tb.WriteString(styles[z].Render(run.String()))\n\t\t\tj = k\n\t\t}\n\t\tresult[i] = b.String()\n\t}\n\treturn result\n}\n\nfunc sideBySide(popsicles []string, textRows []string, startRow int, tagline string) {\n\ttagRow := startRow + len(textRows) // no gap between text and tagline\n\tfor i, line := range popsicles {\n\t\tswitch {\n\t\tcase i >= startRow && i-startRow < len(textRows):\n\t\t\tfmt.Printf(\"%s   %s\\n\", line, textRows[i-startRow])\n\t\tcase tagline != \"\" && i == tagRow:\n\t\t\tfmt.Printf(\"%s   %s\\n\", line, tagline)\n\t\tdefault:\n\t\t\tfmt.Println(line)\n\t\t}\n\t}\n}\n\nfunc main() {\n\tre := lipgloss.NewRenderer(os.Stdout)\n\tre.SetColorProfile(termenv.TrueColor)\n\n\tdim := re.NewStyle().Foreground(lipgloss.Color(\"#888888\"))\n\tdivider := re.NewStyle().Foreground(lipgloss.Color(\"#444444\"))\n\n\tpopsicles := renderPopsicleArt(re)\n\ttagline := dim.Render(\"by 37signals\")\n\n\tdiv := func(label string) {\n\t\tfmt.Printf(\"\\n%s\\n\\n\", divider.Render(\"в”Ғв”Ғв”Ғ \"+label+\" в”Ғв”Ғв”Ғ\"))\n\t}\n\n\t// 1: Full banner with tagline nestled under Fizzy\n\tdiv(\"1: Full banner + tagline nestled under Fizzy\")\n\tfullBanner := renderFullBanner(re)\n\tfor _, line := range fullBanner {\n\t\tfmt.Println(line)\n\t}\n\t// Position tagline right-aligned under the FIZZY text, no blank line\n\tfmt.Printf(\"%s%s\\n\", strings.Repeat(\" \", 66), tagline)\n\n\t// B: Braille 2x Fizzy\n\tdiv(\"B: Braille 2x Fizzy\")\n\tfizzyB := composeFizzy(fizzyLetters, renderBraille, scale2x, re, \" \")\n\tsideBySide(popsicles, fizzyB, 3, tagline)\n\n\t// C: Half-block Fizzy\n\tdiv(\"C: Half-block Fizzy\")\n\tfizzyC := composeFizzy(fizzyLetters, renderHalfBlock, nil, re, \" \")\n\tsideBySide(popsicles, fizzyC, 3, tagline)\n\n\t// H1: Hybrid (block + braille) 1x\n\tdiv(\"H1: Hybrid block+braille 1x Fizzy\")\n\tfizzyH1 := composeFizzy(fizzyLetters, renderHybrid, nil, re, \" \")\n\tsideBySide(popsicles, fizzyH1, 4, tagline)\n\n\t// H2: Hybrid (block + braille) 2x\n\tdiv(\"H2: Hybrid block+braille 2x Fizzy\")\n\tfizzyH2 := composeFizzy(fizzyLetters, renderHybrid, scale2x, re, \" \")\n\tsideBySide(popsicles, fizzyH2, 3, tagline)\n\n\t// F: Simple rainbow Fizzy (baseline, no gap)\n\tdiv(\"F: Simple rainbow Fizzy\")\n\tvar fizzyText strings.Builder\n\tfor i, l := range []string{\"F\", \"i\", \"z\", \"z\", \"y\"} {\n\t\tfizzyText.WriteString(re.NewStyle().Foreground(tui.PopsicleColors[i]).Bold(true).Render(l))\n\t}\n\tfor i, line := range popsicles {\n\t\tswitch i {\n\t\tcase 5:\n\t\t\tfmt.Printf(\"%s   %s\\n\", line, fizzyText.String())\n\t\tcase 6:\n\t\t\tfmt.Printf(\"%s   %s\\n\", line, tagline)\n\t\tdefault:\n\t\t\tfmt.Println(line)\n\t\t}\n\t}\n\n\tfmt.Println()\n}\n",
