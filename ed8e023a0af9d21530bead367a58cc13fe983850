opVisWidth := lipgloss.Width(popsicles[1]) // pick a full row\n\n\t// Left margin: match the leading blank braille in the popsicle art.\n\t// The banner lines start with ~3 blank braille chars before the first popsicle.\n\tmargin := strings.Repeat(\" \", 3)\n\n\tdiv := func(label string) {\n\t\tfmt.Printf(\"\\n%s\\n\\n\", divider.Render(\"в”Ғв”Ғв”Ғ \"+label+\" в”Ғв”Ғв”Ғ\"))\n\t}\n\n\t// --- 1A: Full banner, brighter colors + bold ---\n\tdiv(\"1A: Full banner BOLD + brighter colors\")\n\tbanner1a := renderFullBannerBright(re, \"by 37signals\", 55, 10)\n\tfor _, line := range banner1a {\n\t\tfmt.Println(line)\n\t}\n\n\t// --- F variants: \"Fizzy by 37signals\" with alignment ---\n\n\t// Build rainbow \"Fizzy\" using tint colors (lighter/brighter)\n\tvar fizzyText strings.Builder\n\tfor i, l := range []string{\"F\", \"i\", \"z\", \"z\", \"y\"} {\n\t\tfizzyText.WriteString(re.NewStyle().Foreground(tintColors[i]).Bold(true).Render(l))\n\t}\n\tfizzy := fizzyText.String()\n\tby37 := dim.Render(\"by 37signals\")\n\n\t// Combined \"Fizzy by 37signals\"\n\tcombined := fizzy + \" \" + by37\n\tcombinedPlain := \"Fizzy by 37signals\"\n\tcombinedWidth := len(combinedPlain)\n\n\t// Content width inside the margin (visual width minus the 3-char margin on each side)\n\tinnerWidth := popVisWidth - 3 // left margin only; right edge is the art boundary\n\n\t// Left-aligned (with margin)\n\tdiv(\"F-left: left aligned\")\n\tfor _, line := range popsicles {\n\t\tfmt.Println(line)\n\t}\n\tfmt.Println()\n\tfmt.Println(margin + combined)\n\n\t// Center-aligned\n\tcenterPad := (innerWidth - combinedWidth) / 2\n\tif centerPad < 0 {\n\t\tcenterPad = 0\n\t}\n\tdiv(\"F-center: center aligned\")\n\tfor _, line := range popsicles {\n\t\tfmt.Println(line)\n\t}\n\tfmt.Println()\n\tfmt.Println(margin + strings.Repeat(\" \", centerPad) + combined)\n\n\t// Right-aligned (flush with right edge of popsicle art)\n\trightPad := innerWidth - combinedWidth\n\tif rightPad < 0 {\n\t\trightPad = 0\n\t}\n\tdiv(\"